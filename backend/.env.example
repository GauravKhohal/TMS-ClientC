# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string for THIS client's own database (separate from any other client's DB)
# Local/migrations: use the public/proxy connection string
DATABASE_URL="postgresql://user:password@host:port/dbname"
# Railway backend service only: use the *.railway.internal connection string
# DATABASE_URL_RAILWAY_INTERNAL="postgresql://postgres:password@postgres.railway.internal:5432/railway"

# Generate a NEW random secret for this client (e.g. `openssl rand -hex 32`).
# Must be different from other clients' secrets so JWTs aren't valid across deployments.
JWT_SECRET=

# Backend port (Railway sets this automatically; default 5001 for local dev)
PORT=5001

# Comma-separated list of allowed frontend origins for CORS (this client's Vercel URL)
FRONTEND_URL=

# Mappls (MapmyIndia) API key for this client, if used
MAPPLS_KEY=

# Meta WhatsApp Cloud API (optional) — for trip-summary WhatsApp messages
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
